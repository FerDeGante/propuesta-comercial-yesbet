{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/audit.html",
      "destination": "/audit",
      "permanent": true
    },
    {
      "source": "/audit/",
      "destination": "/audit",
      "permanent": true
    },
    {
      "source": "/propuesta.html",
      "destination": "/propuesta",
      "permanent": true
    },
    {
      "source": "/propuesta/",
      "destination": "/propuesta",
      "permanent": true
    },
    {
      "source": "/meta.html",
      "destination": "/meta",
      "permanent": true
    },
    {
      "source": "/meta/",
      "destination": "/meta",
      "permanent": true
    },
    {
      "source": "/plan-meta.html",
      "destination": "/plan-meta",
      "permanent": true
    },
    {
      "source": "/plan-meta/",
      "destination": "/plan-meta",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/audit",
      "destination": "/audit.html"
    },
    {
      "source": "/propuesta",
      "destination": "/propuesta.html"
    },
    {
      "source": "/meta",
      "destination": "/meta.html"
    },
    {
      "source": "/plan-meta",
      "destination": "/plan-meta.html"
    }
  ]
}
